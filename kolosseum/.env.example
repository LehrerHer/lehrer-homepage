PORT=3000
SESSION_SECRET=hier_langes_zufaelliges_secret_eintragen
ADMIN_PASSWORD_HASH=hier_bcrypt_hash_des_adminpassworts
DB_PATH=./db/kolosseum.db
# Erlaubte E-Mail-Domains für Selbstregistrierung (kommagetrennt)
ALLOWED_DOMAINS=obsspelle.de

# Auto-Deploy via GitHub-Webhook
# Zufälliges Secret generieren: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
DEPLOY_SECRET=hier_zufaelliges_webhook_secret_eintragen
DEPLOY_DIR=/var/www/lehrer-homepage
PM2_APP=kolosseum
