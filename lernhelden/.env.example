PORT=3000
SESSION_SECRET=hier_langes_zufaelliges_secret_eintragen_mindestens_32_zeichen
ADMIN_PASSWORD_HASH=hier_bcrypt_hash_des_adminpassworts

# Hash generieren:
# node -e "const b=require('bcryptjs'); b.hash('DeinPasswort',10).then(h=>console.log(h))"
# Oder beim ersten Start wird Standard-Passwort "lernhelden" verwendet (Warnung im Log)

# ── Supabase (Datenbank) ─────────────────────────────────────────────────────
# Connection String aus Supabase Dashboard → Project Settings → Database → URI
# Direct Connection (empfohlen für dauerhaft laufenden Server):
DATABASE_URL=postgresql://postgres:[DEIN-PASSWORT]@db.[DEIN-PROJEKT-REF].supabase.co:5432/postgres

# SSL deaktivieren (nur für lokale PostgreSQL-Instanz ohne SSL):
# DATABASE_SSL=false
